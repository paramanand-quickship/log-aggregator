<%- include('partials/head', { title: 'Logs' }) %>
<style>
  .level-icon { display:inline-flex; align-items:center; justify-content:center; width:20px; height:20px; border-radius:4px; flex-shrink:0; }
  .level-icon.error { background:rgba(239,68,68,.15); }
  .level-icon.warn  { background:rgba(245,158,11,.15); }
  .level-icon.info  { background:rgba(59,130,246,.15); }
  .level-icon.debug { background:rgba(107,114,128,.15); }
</style>
<div class="app-shell">
  <%- include('partials/sidebar') %>
  <div class="main-area">
    <header class="top-header">
      <div class="page-title">Logs</div>
      <div class="header-actions">
        <% if (selected.service && selected.date) { %>
        <a href="/api/logs/download/<%= selected.service %>/<%= selected.date %><%= selected.level ? '?level='+selected.level : '' %><%= selected.q ? (selected.level?'&':'?')+'q='+selected.q : '' %>" class="btn btn-secondary btn-sm">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
        <% } %>
      </div>
    </header>

    <div class="page-content">
      <!-- Filters -->
      <div class="card" style="margin-bottom:12px;">
        <form method="GET" action="/logs" id="search-form">
          <div class="form-row" style="gap:10px;flex-wrap:wrap;">
            <div class="form-group" style="min-width:160px;flex:1.5">
              <label class="form-label">Service</label>
              <select name="service" class="form-select" onchange="this.form.submit()">
                <option value="">— All Services —</option>
                <% services.forEach(function(s) { %>
                <option value="<%= s.appName %>" <%= selected.service===s.appName?'selected':'' %>><%= s.appName %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group" style="min-width:140px;">
              <label class="form-label">Date</label>
              <input type="date" name="date" class="form-input" value="<%= selected.date %>" max="<%= today %>" onchange="this.form.submit()"/>
            </div>
            <div class="form-group" style="min-width:120px;">
              <label class="form-label">Level</label>
              <select name="level" class="form-select">
                <option value="">All Levels</option>
                <option value="error" <%= selected.level==='error'?'selected':'' %>>Error</option>
                <option value="warn"  <%= selected.level==='warn' ?'selected':'' %>>Warn</option>
                <option value="info"  <%= selected.level==='info' ?'selected':'' %>>Info</option>
                <option value="debug" <%= selected.level==='debug'?'selected':'' %>>Debug</option>
              </select>
            </div>
            <div class="form-group" style="flex:2;min-width:200px;">
              <label class="form-label">Keyword Search</label>
              <div class="search-wrap">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" name="q" class="form-input search-input" placeholder="Search logs…" value="<%= selected.q %>"/>
              </div>
            </div>
            <div class="form-group" style="display:flex;align-items:flex-end;gap:6px;min-width:auto;">
              <button type="submit" class="btn btn-primary">Search</button>
              <a href="/logs" class="btn btn-secondary">Reset</a>
            </div>
          </div>
        </form>

        <!-- Quick filter chips with icons -->
        <div class="chip-bar" style="margin-top:12px;padding-top:10px;border-top:1px solid var(--border);">
          <span style="font-size:11px;color:var(--text3);font-weight:500;margin-right:2px;">Quick:</span>
          <a href="/logs?service=<%= selected.service %>&date=<%= selected.date %>&level=error" class="chip error <%= selected.level==='error'?'active':'' %>">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Error
          </a>
          <a href="/logs?service=<%= selected.service %>&date=<%= selected.date %>&level=warn" class="chip warn <%= selected.level==='warn'?'active':'' %>">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Warn
          </a>
          <a href="/logs?service=<%= selected.service %>&date=<%= selected.date %>&level=info" class="chip info <%= selected.level==='info'?'active':'' %>">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            Info
          </a>
          <a href="/logs?service=<%= selected.service %>&date=<%= selected.date %>&level=debug" class="chip debug <%= selected.level==='debug'?'active':'' %>">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
            Debug
          </a>
          <% if (selected.level) { %>
          <a href="/logs?service=<%= selected.service %>&date=<%= selected.date %>" class="chip" style="margin-left:4px;color:var(--text3);">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Clear filter
          </a>
          <% } %>
        </div>
      </div>

      <!-- Results -->
      <div class="card">
        <% if (!selected.service) { %>
          <div class="empty-state">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
            <p>Select a service to view logs</p>
          </div>
        <% } else if (!results || !results.lines || !results.lines.length) { %>
          <div class="empty-state">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <p>No logs found for <strong><%= selected.service %></strong> on <strong><%= selected.date %></strong></p>
          </div>
        <% } else {
          // Pre-filter
          var filteredLines = results.lines.filter(function(line) {
            var parsed = null, level = 'info';
            try { parsed = JSON.parse(line); level = (parsed.level||'info').toLowerCase(); } catch(e){}
            if (selected.level && level !== selected.level) return false;
            if (selected.q && line.toLowerCase().indexOf(selected.q.toLowerCase()) === -1) return false;
            return true;
          });
        %>
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div style="font-size:12px;color:var(--text2);">
                Showing <strong style="color:var(--text)"><%= filteredLines.length %></strong>
                <% if (filteredLines.length !== results.lines.length) { %>of <%= results.lines.length %><% } %>
                lines from <strong style="color:var(--text)"><%= selected.service %></strong>
              </div>
              <!-- Inline level summary pills -->
              <% var lvlCounts = {error:0,warn:0,info:0,debug:0}; filteredLines.forEach(function(l){try{var p=JSON.parse(l);lvlCounts[(p.level||'info').toLowerCase()]=(lvlCounts[(p.level||'info').toLowerCase()]||0)+1;}catch(e){}}) %>
              <% if (lvlCounts.error > 0) { %><span class="badge badge-error" style="font-size:10px;"><%= lvlCounts.error %> error<% if(lvlCounts.error>1)%>s</span><% } %>
              <% if (lvlCounts.warn > 0) { %><span class="badge badge-warn" style="font-size:10px;"><%= lvlCounts.warn %> warn</span><% } %>
            </div>
            <label style="font-size:12px;color:var(--text3);display:flex;align-items:center;gap:5px;cursor:pointer;">
              <input type="checkbox" id="wrap-toggle" onchange="toggleWrap(this)"/> Wrap text
            </label>
          </div>

          <div class="log-list" id="log-list">
            <% filteredLines.forEach(function(line, idx) {
              var parsed = null, level = 'info', ts = '', msg = '', svc = '';
              try {
                parsed = JSON.parse(line);
                level  = (parsed.level || 'info').toLowerCase();
                ts     = parsed.ts ? parsed.ts.replace('T',' ').slice(0,19) : '';
                msg    = parsed.message || parsed.msg || line;
                svc    = parsed.appName || '';
              } catch(e) { msg = line; }
            %>
            <div class="log-line level-<%= level %>" onclick="toggleLine(this)">
              <span class="level-icon <%= level %>">
                <% if (level === 'error') { %>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <% } else if (level === 'warn') { %>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                <% } else if (level === 'info') { %>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                <% } else { %>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg>
                <% } %>
              </span>
              <span class="log-ts"><%= ts %></span>
              <span class="log-body" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= msg %></span>
              <% if (svc) { %><span style="font-size:10px;color:var(--text3);white-space:nowrap;font-family:'JetBrains Mono',monospace;padding:1px 6px;background:var(--surface2);border-radius:3px;"><%= svc %></span><% } %>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="expand-icon" style="flex-shrink:0;color:var(--text3);transition:transform .15s;"><polyline points="6,9 12,15 18,9"/></svg>
            </div>
            <div class="log-expanded" style="display:none">
              <pre class="log-json"><%= parsed ? JSON.stringify(parsed, null, 2) : line %></pre>
            </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
function toggleLine(el) {
  const next = el.nextElementSibling;
  if (!next) return;
  const open = next.style.display === '';
  next.style.display = open ? 'none' : '';
  el.classList.toggle('expanded', !open);
  const icon = el.querySelector('.expand-icon');
  if (icon) icon.style.transform = open ? '' : 'rotate(180deg)';
}
function toggleWrap(cb) {
  document.querySelectorAll('.log-body').forEach(el => {
    el.style.whiteSpace = cb.checked ? 'pre-wrap' : 'nowrap';
    el.style.overflow   = cb.checked ? 'visible'  : 'hidden';
    el.style.textOverflow = cb.checked ? 'clip' : 'ellipsis';
  });
}
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'f') { e.preventDefault(); document.querySelector('[name="q"]').focus(); }
});
</script>
</body></html>
