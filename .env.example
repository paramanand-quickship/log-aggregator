PORT=9900
NODE_ENV=development

# Log storage
LOG_BASE_DIR=./logs
RETENTION_DAYS=7
CLEANUP_INTERVAL=86400000

# Batching
BATCH_SIZE=20
BATCH_TIMEOUT=200

# Security — MUST change these in production
JWT_SECRET=replace-with-a-secure-random-string-min-32-chars
API_KEY=replace-with-a-secure-api-key
SESSION_NAME=log_session
MAX_BODY_SIZE=10mb

# Features
ENABLE_STREAM=true

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=http://localhost:9900
